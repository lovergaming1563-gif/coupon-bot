# ══════════════════════════════════════════
#  Coupon Bot — Environment Variables
#  Rename this file to: .env
#  Location: /home/ubuntu/coupon-bot/.env
# ══════════════════════════════════════════

# Telegram Bot Token (BotFather se mila tha)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram Admin ID (tera Telegram ID)
TELEGRAM_ADMIN_ID=6724474397

# Session Secret (koi bhi random string)
SESSION_SECRET=MySecretKey123RandomString

# Bot Username (bina @)
BOT_USERNAME=MyntraCouponStores_bot

# Data directory (mat badlo)
BOT_DATA_DIR=/home/ubuntu/bot_data

# API Server URL for referral tracking
# Oracle VM ka Public IP yahan daalo: http://YOUR_VM_IP:8080
REFERRAL_BASE_URL=http://YOUR_VM_PUBLIC_IP:8080
